<Window x:Class="ResticUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ResticUI" Height="500" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Restic">
                <MenuItem Header="List _Snapshots" Click="ListSnapshots_Click"/>
                <MenuItem Header="List _Files" Click="ListFiles_Click" Name="ListFilesMenuItem"/>
                <MenuItem Header="List Files (_Detailed)" Click="ListFilesDetailed_Click" Name="ListFilesDetailedMenuItem"/>
                <Separator/>
                <MenuItem Header="_Backup..." Click="Backup_Click"/>
                <MenuItem Header="Re_store Snapshot..." Click="RestoreSnapshot_Click" Name="RestoreSnapshotMenuItem"/>
                <MenuItem Header="Remove _Snapshot..." Click="RemoveSnapshot_Click" Name="RemoveSnapshotMenuItem"/>
                <Separator/>
                <MenuItem Header="Run Backup _Script" Click="RunBackupScript_Click"/>
            </MenuItem>
        </Menu>
        
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <ListView x:Name="SnapshotsListView" Grid.Row="0" Margin="5" SelectionChanged="SnapshotsListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ShortId}" Width="100"/>
                        <GridViewColumn Header="Time" DisplayMemberBinding="{Binding time}" Width="150"/>
                        <GridViewColumn Header="Paths" DisplayMemberBinding="{Binding PathsDisplay}" Width="300"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Gray"/>

            <TextBox x:Name="LogTextBox" Grid.Row="2" Margin="5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>
        </Grid>
    </DockPanel>
</Window>
