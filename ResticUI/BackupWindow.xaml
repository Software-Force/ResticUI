<Window x:Class="ResticUI.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Backup" Height="400" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select files and folders to backup:" Margin="0,0,0,5"/>

        <ListBox x:Name="PathsListBox" Grid.Row="1" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Add Folder" Width="100" Margin="0,0,5,0" Click="AddFolder_Click"/>
            <Button Content="Add File" Width="100" Margin="0,0,5,0" Click="AddFile_Click"/>
            <Button Content="Remove Selected" Width="120" Click="Remove_Click"/>
        </StackPanel>

        <DockPanel Grid.Row="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save as Script..." Width="120" Margin="5" Click="SaveScript_Click"/>
                <Button Content="Run Backup" Width="100" Margin="5" Click="RunBackup_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                <Button Content="Cancel" Width="80" Margin="5" Click="Cancel_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
